option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    # Raised for a larger instance so Node + parallel Chromium instances
    # don't thrash the heap.
    NODE_OPTIONS: "--max-old-space-size=4096"
    # Point npm at webapp's home so prebuild (root) and npm install (webapp)
    # can't create permission conflicts. Explicit override neutralizes any
    # stale value left over from previous deploys.
    npm_config_cache: "/home/webapp/.npm"
    # Both JOB_CONCURRENCY and RENDER_WORKERS are auto-computed from detected
    # vCPU + RAM at boot (see src/config.js). Resulting defaults per Spot type:
    #   t3.xlarge  (4 vCPU, 16 GB)   → concurrency=2, workers=2 (4 threads, fits 4 vCPU)
    #   c4.xlarge  (4 vCPU,  7.5 GB) → concurrency=3, workers=1 (RAM-constrained)
    #   c5.xlarge  (4 vCPU,  8 GB)   → concurrency=3, workers=1 (RAM-constrained)
    #   t3.2xlarge (8 vCPU, 32 GB)   → concurrency=3, workers=2 (6 threads)
    JOB_CONCURRENCY: "auto"
    RENDER_WORKERS: "auto"
    RENDER_QUALITY: "draft"
  # Spot fleet config (console-set values preserved if set there).
  # Uncomment to override via .ebextensions (priority-ordered):
  # aws:ec2:instances:
  #   EnableSpot: true
  #   InstanceTypes: "t3.xlarge,c4.xlarge,c5.xlarge,t3.2xlarge"
  #   SpotAllocationStrategy: price-capacity-optimized
  # aws:autoscaling:asg:
  #   CapacityRebalance: true
  aws:autoscaling:launchconfiguration:
    RootVolumeType: gp3
    RootVolumeSize: "20"
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthCheckInterval: "30"
    HealthCheckTimeout: "10"
    HealthyThresholdCount: "2"
    UnhealthyThresholdCount: "5"
